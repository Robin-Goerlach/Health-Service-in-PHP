Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Interne Verzeichnisse sollen nicht direkt aufrufbar sein.
    RewriteRule ^(config|src)(/|$) - [F,L]

    # Falls später weitere interne Pfade dazukommen, landet alles Übrige auf index.php.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
