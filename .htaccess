Options -Indexes -MultiViews
DirectoryIndex index.php

ErrorDocument 404 /error_404_sasd.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Interne Verzeichnisse sollen nicht direkt aufrufbar sein.
    RewriteRule ^(config|src)(/|$) - [F,L]

    # Reale Dateien und Verzeichnisse werden direkt bedient.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Alles andere wird an index.php weitergereicht.
    RewriteRule ^ index.php [QSA,L]
</IfModule>
